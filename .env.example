# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3005/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# ─── Admin Portal ─────────────────────────────────────────────────────────────
# Obscure path for admin portal — change this to something random before deploying!
VITE_ADMIN_PORTAL_PATH=/x-portal-9f3a
# Must match ADMIN_SECRET_KEY in server/.env
VITE_ADMIN_SECRET_KEY=GENERATE_A_STRONG_RANDOM_KEY_HERE

# ─── Server (server/.env) ────────────────────────────────────────────────────
# Copy the following into server/.env

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Server
PORT=3005
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Admin Security — MUST be a long, random secret (minimum 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET_KEY=GENERATE_A_STRONG_RANDOM_KEY_HERE

# External Services (optional)
GOTENBERG_URL=http://localhost:3001
CONVERTER_URL=http://localhost:3006
