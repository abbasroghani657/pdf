{
  "name": "pdf-toolkit-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host",
    "prebuild": "node scripts/generate-sitemap.js",
    "build": "node scripts/generate-sitemap.js && vite build && node scripts/build-seo-html.js && node scripts/build-blog-html.js",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "server": "node server/index.js",
    "python": "cd converter-service && py app.py",
    "start": "concurrently \"npm run dev\" \"npm run server\"",
    "start:all": "concurrently \"npm run dev\" \"npm run server\" \"npm run python\"",
    "electron:dev": "concurrently -k \"vite\" \"electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@stripe/stripe-js": "^9.7.0",
    "@supabase/supabase-js": "^2.107.0",
    "@types/dompurify": "^3.0.5",
    "axios": "^1.16.1",
    "clsx": "^2.1.0",
    "concurrently": "^8.2.2",
    "dompurify": "^3.4.8",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.39.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.1",
    "iconify-icon": "^2.1.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^15.0.0",
    "react-helmet-async": "^3.0.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.theylovepdf.desktop",
    "productName": "TheyLovePDF",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "chrome-extension/icons/icon128.png",
      "fileAssociations": [
        {
          "ext": "pdf",
          "name": "PDF Document",
          "role": "Editor"
        }
      ]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "chrome-extension/icons/icon128.png",
      "fileAssociations": [
        {
          "ext": "pdf",
          "name": "PDF Document",
          "role": "Editor"
        }
      ]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "chrome-extension/icons/icon128.png",
      "category": "Office"
    }
  }
}
