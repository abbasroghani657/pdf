{
  "manifest_version": 3,
  "name": "TheyLovePDF: Free PDF Tools",
  "version": "1.0.0",
  "description": "Edit, merge, split, and compress PDF files directly from your browser. 100% secure offline processing for Pro users.",
  "permissions": [
    "contextMenus",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://*.theylovepdf.com/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TheyLovePDF Toolkit"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
