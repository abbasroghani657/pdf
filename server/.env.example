PORT=3005
APP_URL=http://localhost:3000

# AI Keys (Free)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEY2=optional_second_key
GROQ_API_KEY=your_groq_key_here

# Email (Gmail — used for admin invitations, password reset, etc.)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME=PDFMaster

# SMTP for Subscription Expiry Emails (subscriptionCron.js)
# Use same Gmail credentials or a transactional service (e.g. SendGrid, Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SITE_NAME=PDFMaster

# Services
GOTENBERG_URL=http://localhost:3001
CONVERTER_URL=http://localhost:3006
FRONTEND_URL=http://localhost:3000

# Supabase Keys
SUPABASE_URL=your_supabase_url
